{
  "expo": {
    "name": "LumaScout",
    "slug": "lumascout",
    "version": "2.0.15",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lumascout",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "runtimeVersion": "1.0.0",
    "updates": {
      "enabled": false,
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.emergent.photofinder60669d6fa1",
      "buildNumber": "2.0.15",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Show nearby photoshoot spots and save locations.",
        "NSPhotoLibraryUsageDescription": "Upload photos for your photoshoot spots.",
        "NSPhotoLibraryAddUsageDescription": "Save spot photos to your camera roll.",
        "NSCameraUsageDescription": "Capture photos for your photoshoot spots.",
        "NSUserTrackingUsageDescription": "We use this to improve LumaScout recommendations and personalization.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.lumascout.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://lumascout.app"
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow LumaScout to use your location to find nearby spots."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow LumaScout to access your photos to upload spot images."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash/Splash-LumaScout.png",
          "resizeMode": "cover",
          "backgroundColor": "#020816",
          "dark": {
            "image": "./assets/splash/Splash-LumaScout.png",
            "resizeMode": "cover",
            "backgroundColor": "#020816"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {
        "origin": "https://lumascout.app"
      },
      "eas": {
        "projectId": "343f8686-eae5-481d-b558-8370c82e4fef"
      },
      "privacyPolicyUrl": "https://lumascout.app/privacy"
    },
    "owner": "lumascout"
  }
}
