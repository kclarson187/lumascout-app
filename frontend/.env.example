# ─────────────────────────────────────────────────────────────────────
# LumaScout frontend environment template (commit-safe placeholders).
# ─────────────────────────────────────────────────────────────────────
# Copy to `frontend/.env` locally OR configure via the Emergent platform.
# The real `frontend/.env` is GITIGNORED. NEVER commit live keys.
#
# Note: any EXPO_PUBLIC_* value is BAKED INTO the JS bundle and visible
# to anyone who installs the app. Only put values here that are safe
# to expose to clients (Stripe publishable keys, RevenueCat public
# SDK keys, public CDN hosts). Server-side secrets belong in backend/.env.

# ─── Expo packager (managed by Emergent — do not change locally) ──
EXPO_TUNNEL_SUBDOMAIN=your-tunnel-subdomain
EXPO_PACKAGER_HOSTNAME=https://your-tunnel-host.example.com
EXPO_PACKAGER_PROXY_URL=https://your-tunnel-host.example.com

# ─── Public backend URL ───────────────────────────────────────────
# Where the frontend calls /api/* against in the deployed environment.
EXPO_PUBLIC_BACKEND_URL=https://your-backend.example.com

# ─── Canonical web origin (share sheets, OG previews, Universal Links) ───
# MUST match expo.ios.associatedDomains + expo.android.intentFilters
# in app.json. See universal-links/ for AASA + assetlinks.json hosts.
EXPO_PUBLIC_WEB_BASE_URL=https://your-app.example.com

# ─── Metro resolver settings ──────────────────────────────────────
EXPO_USE_FAST_RESOLVER="1"
METRO_CACHE_ROOT=/app/frontend/.metro-cache

# ─── Stripe (live publishable key — pk_live_…) ────────────────────
# Publishable keys are safe to ship in client bundles. Get yours from
# Stripe Dashboard → Developers → API keys.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY_HERE

# ─── Public share base host (display + canonical confirmation) ────
EXPO_PUBLIC_SHARE_BASE_URL=https://your-share-host.example.com

# ─── RevenueCat — iOS public SDK API key ──────────────────────────
# RevenueCat Dashboard → Project Settings → API keys → iOS app.
# Public SDK keys are safe to ship in the iOS bundle.
EXPO_PUBLIC_RC_IOS_API_KEY=YOUR_RC_IOS_PUBLIC_API_KEY_HERE
