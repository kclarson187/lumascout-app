web/node_modules/@next/swc-linux-arm64-musl/next-swc.linux-arm64-musl.node

# ----------------------------------------------------------------------------
# Credentials & secrets
# NOTE: .env files are intentionally NOT ignored — the Emergent deployment
# pipeline needs them at build time. Real production secrets live in the
# platform secret store, NOT in committed .env files.
# ----------------------------------------------------------------------------
credentials.json
*token.json*
*credentials.json*
*.pem
*.key
.credentials

# Apple ASC API Key + secrets
secrets/
*.p8
credentials*.disabled-*

# Allow EAS local credentials.json for iOS build pipeline
!frontend/credentials.json

# DO NOT ADD .env / .env.* / *.env BLOCK RULES BELOW THIS LINE.
# As stated above, .env files (backend/.env and frontend/.env) MUST be
# committed for the Emergent deployment pipeline. Adding global .env
# ignore rules WILL cause a production outage (Cloudflare 520) because
# the backend pod will start with no MONGO_URL, no Stripe keys, etc.
# Local-only overrides (.env.local) are still ignored via
# frontend/.gitignore's `.env*.local` rule.
.env
.env.*
*.env
