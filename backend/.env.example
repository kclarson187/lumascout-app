# ─────────────────────────────────────────────────────────────────────
# LumaScout backend environment template (commit-safe placeholders).
# ─────────────────────────────────────────────────────────────────────
# Copy this file to `backend/.env` locally OR set these values in the
# Emergent deployment platform secret store. The real `backend/.env`
# is GITIGNORED — never commit live secrets.
#
# Replace every YOUR_..._HERE value with the real credential before
# starting the backend.

# ─── Mongo + JWT ──────────────────────────────────────────────────
MONGO_URL="mongodb://localhost:27017"
DB_NAME="photoscout_database"
# 64-char hex; rotate if ever leaked. Generate locally with:
#   python -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET="YOUR_JWT_SECRET_HEX_HERE"

# ─── Bootstrap admin (only used on first DB seed) ─────────────────
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="YOUR_ADMIN_PASSWORD_HERE"

# ─── Emergent Universal LLM Key ───────────────────────────────────
# Pulled from your Emergent profile → Universal Key. Powers the
# Claude / GPT-5.2 / Gemini text + image calls used in this repo.
EMERGENT_LLM_KEY=YOUR_EMERGENT_LLM_KEY_HERE

# ─── Stripe (live mode in production) ─────────────────────────────
# Use a RESTRICTED live key (rk_live_…) scoped to customers /
# checkout sessions / subscriptions / products / prices / invoices /
# charges. NEVER expose this to any frontend bundle.
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
# Webhook secret from Stripe Dashboard → Developers → Webhooks.
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE

# ─── Mapbox / Postmark ────────────────────────────────────────────
MAPBOX_TOKEN=YOUR_MAPBOX_PUBLIC_TOKEN_HERE
POSTMARK_SERVER_TOKEN=YOUR_POSTMARK_SERVER_TOKEN_HERE

# ─── App URLs ─────────────────────────────────────────────────────
APP_URL=https://your-app.example.com

# ─── Apple Push (APNs direct dispatch) ────────────────────────────
# The .p8 is stored OUTSIDE the repo (e.g. /app/secrets/).
APNS_KEY_ID=YOUR_APNS_KEY_ID_HERE
APNS_TEAM_ID=YOUR_APPLE_TEAM_ID_HERE
APNS_BUNDLE_ID=app.example.yourbundle
APNS_KEY_PATH=/app/secrets/AuthKey_YOUR_APNS_KEY_ID_HERE.p8
APNS_USE_SANDBOX=false

# ─── Cloudflare R2 object storage ─────────────────────────────────
# Omit any of these 5 keys to fall back to on-disk writes (dev mode).
R2_ACCOUNT_ID=YOUR_R2_ACCOUNT_ID_HERE
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID_HERE
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY_HERE
R2_BUCKET=your-bucket-name
R2_PUBLIC_BASE_URL=https://pub-YOUR_R2_PUBLIC_HASH_HERE.r2.dev

# ─── Public share base URL ────────────────────────────────────────
PUBLIC_SHARE_BASE_URL=https://your-public-host.example.com

# ─── RevenueCat (iOS subscriptions) ───────────────────────────────
# Shared secret matched against RevenueCat dashboard → Integrations →
# Webhooks → Authorization header.
REVENUECAT_WEBHOOK_AUTH=YOUR_REVENUECAT_WEBHOOK_AUTH_HERE

# ─── Apple Sign In with Apple (Jun 2026) ──────────────────────────
# Optional override — only set if the iOS bundle ID changes.
# APPLE_BUNDLE_ID=app.example.yourbundle
